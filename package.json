{
  "name": "windows-portable-packager",
  "version": "0.0.16",
  "description": "Go-based portable launcher for Windows Electron apps — hash verification, version management, multi-arch support, and electron-builder integration",
  "bin": {
    "windows-portable-packager": "bin/windows-portable-packager.js"
  },
  "main": "./hooks/afterAllArtifactBuild.js",
  "files": [
    "bin/",
    "hooks/",
    "lib/",
    "embedded/app.kbpkg",
    "embedded/splash.dat",
    "embedded/splash.ext",
    "dist/windows-portable-packager-*.exe",
    "internal/app/*.go",
    "!internal/app/*_test.go",
    "embed.go",
    "main.go",
    "go.mod",
    "go.sum"
  ],
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.js",
      "!**/test/**/*.integration.test.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "\\.integration\\.test\\.js$"
    ]
  },
  "scripts": {
    "build:go": "go build -ldflags=\"-s -w -H=windowsgui\" -o dist/windows-portable-packager.exe .",
    "build:all": "node scripts/build-all.js",
    "build": "npm run build:go",
    "test:go": "go test ./internal/app/ -v -count=1",
    "test:node": "jest",
    "test:integration": "jest --config jest.integration.config.js",
    "test": "npm run test:go && npm run test:node",
    "prepack": "npm run build:all"
  },
  "peerDependencies": {
    "electron-builder": ">= 22.0.0"
  },
  "peerDependenciesMeta": {
    "electron-builder": {
      "optional": true
    }
  },
  "keywords": [
    "electron",
    "electron-builder",
    "portable",
    "launcher",
    "windows",
    "hash-verification",
    "multi-arch"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hhgyu/windows-portable-packager.git"
  },
  "license": "MIT",
  "devDependencies": {
    "jest": "^30.3.0"
  }
}


